# Ignore Gradle build artifacts
build/

# Ignore IDE files
.idea/
.vscode/

# Ignore Gradle wrapper files (though they might be needed for some setups)
# gradle/wrapper/gradle-wrapper.jar
# gradle/wrapper/gradle-wrapper.properties

# Ignore environment files containing secrets
.env

# Ignore Gradle caches and other Gradle-related files
.gradle/

# Ignore backend-specific build artifacts
backend/build/
backend/gradle/

# Ignore frontend node_modules and build artifacts
frontend/node_modules/
frontend/dist/

# Ignore other potential build or log files
*.log
*.tmp
